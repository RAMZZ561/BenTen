-- Aimbot Core
local FOVCircle = CreateDrawing("Circle", {Thickness = 1, Color = Color3.fromRGB(0, 162, 255), Filled = false, Visible = false})

local function GetClosest()
    local target, dist = nil, SkyHub.Aimbot.FOV
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(SkyHub.Aimbot.Target) then
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character[SkyHub.Aimbot.Target].Position)
            if onScreen then
                local mag = (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                if mag < dist then
                    dist = mag
                    target = v
                end
            end
        end
    end
    return target
end

RunService.RenderStepped:Connect(function()
    if SkyHub.Aimbot.Enabled then
        FOVCircle.Position = UserInputService:GetMouseLocation()
        FOVCircle.Radius = SkyHub.Aimbot.FOV
        FOVCircle.Visible = SkyHub.Aimbot.ShowFOV
        
        local target = GetClosest()
        if target then
            local tPos = Camera:WorldToViewportPoint(target.Character[SkyHub.Aimbot.Target].Position)
            local mPos = UserInputService:GetMouseLocation()
            local dx, dy = tPos.X - mPos.X, tPos.Y - mPos.Y
            
            if SkyHub.Aimbot.Mode == "Rage" then mousemoverel(dx, dy)
            elseif SkyHub.Aimbot.Mode == "Normal" then mousemoverel(dx/2.5, dy/2.5)
            else mousemoverel(dx/SkyHub.Aimbot.Smooth, dy/SkyHub.Aimbot.Smooth) end
        end
    else FOVCircle.Visible = false end
    
    if SkyHub.Misc.Noclip then
        for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
end)

