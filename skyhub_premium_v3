local function CreateButton(name, parent, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Text = name
    btn.Size = UDim2.new(1, -10, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(25, 30, 35)
    btn.TextColor3 = SkyHub.Theme.Text
