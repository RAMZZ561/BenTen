end

-- Aimbot Logic
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1
FOVCircle.Color = SkyHub.Theme.Accent
FOVCircle.Filled = false
FOVCircle.Visible = false

local function GetClosest()
    local target, dist = nil, SkyHub.Aimbot.FOV
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(SkyHub.Aimbot.Target) then
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character[SkyHub.Aimbot.Target].Position)
            if onScreen then
                local mag = (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                if mag < dist then
                    dist = mag
                    target = v
                end
            end
        end
    end
    return target
end

-- Feature Implementation
RunService.RenderStepped:Connect(function()
    -- Aimbot
    if SkyHub.Aimbot.Enabled then
        FOVCircle.Position = UserInputService:GetMouseLocation()
        FOVCircle.Radius = SkyHub.Aimbot.FOV
        FOVCircle.Visible = true
        
        local target = GetClosest()
        if target then
            local targetPos = Camera:WorldToViewportPoint(target.Character[SkyHub.Aimbot.Target].Position)
            local mousePos = UserInputService:GetMouseLocation()
            local moveX = (targetPos.X - mousePos.X)
            local moveY = (targetPos.Y - mousePos.Y)
            
            if SkyHub.Aimbot.Mode == "Rage" then
                mousemoverel(moveX, moveY)
            elseif SkyHub.Aimbot.Mode == "Normal" then
                mousemoverel(moveX / 3, moveY / 3)
            else
                mousemoverel(moveX / SkyHub.Aimbot.Smooth, moveY / SkyHub.Aimbot.Smooth)
            end
        end
    else
        FOVCircle.Visible = false
    end

    -- Noclip (Universal Replicated)
    if SkyHub.Misc.Noclip then
        for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

-- GUI Tabs Setup
local function ShowTab(name)
    Content:ClearAllChildren()
    local layout = Instance.new("UIListLayout", Content)
    layout.Padding = UDim.new(0, 5)
    
    if name == "Combat" then
        CreateButton("Toggle Aimbot: " .. tostring(SkyHub.Aimbot.Enabled), Content, function()
            SkyHub.Aimbot.Enabled = not SkyHub.Aimbot.Enabled
            ShowTab("Combat")
        end)
        CreateButton("Mode: " .. SkyHub.Aimbot.Mode, Content, function()
            if SkyHub.Aimbot.Mode == "Legit" then SkyHub.Aimbot.Mode = "Normal"
            elseif SkyHub.Aimbot.Mode == "Normal" then SkyHub.Aimbot.Mode = "Rage"
            else SkyHub.Aimbot.Mode = "Legit" end
            ShowTab("Combat")
        end)
    elseif name == "Visual" then
        CreateButton("Toggle ESP: " .. tostring(SkyHub.Visuals.Enabled), Content, function()
            SkyHub.Visuals.Enabled = not SkyHub.Visuals.Enabled
            ShowTab("Visual")
        end)
    elseif name == "Misc" then
        CreateButton("Noclip: " .. tostring(SkyHub.Misc.Noclip), Content, function()
            SkyHub.Misc.Noclip = not SkyHub.Misc.Noclip
            ShowTab("Misc")
        end)
        CreateButton("FPS Boost", Content, function()
            for _, v in pairs(game:GetDescendants()) do
                if v:IsA("DataModelMesh") or v:IsA("Decal") then v:Destroy() end
            end
        end)
        CreateButton("Remove Fog", Content, function()
            game:GetService("Lighting").FogEnd = 9e9
        end)
    end
end

